# Supabase (public anon key — safe for frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Admin user IDs (comma-separated Supabase user UUIDs)
VITE_ADMIN_USER_IDS=

# API server URL
# Local dev: leave empty (Vite proxy handles /api -> localhost:5000)
# Split hosting: https://your-backend.railway.app
# Single hosting: leave empty (same origin)
VITE_API_URL=
