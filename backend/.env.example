# Server
PORT=5000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database (for comms tables)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# CORS (comma-separated origins — leave empty for open CORS in dev)
# Split hosting: https://yourdomain.com
CORS_ORIGINS=

# Security
IP_ENCRYPTION_KEY=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Comms migrations (auto = run on startup, off = use SQL file)
COMMS_MIGRATIONS=auto

# Admin user IDs (for super admin checks)
VITE_ADMIN_USER_IDS=
